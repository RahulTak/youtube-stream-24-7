<?php

declare(strict_types=1);

require dirname(__DIR__) . '/vendor/autoload.php';
require dirname(__DIR__) . '/app/Helpers/functions.php';

use App\Infrastructure\Database;

$pdo = (new Database())->connection();

$pdo->exec(
    'CREATE TABLE IF NOT EXISTS migrations (
        migration VARCHAR(255) PRIMARY KEY,
        applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )'
);

$migrations = glob(dirname(__DIR__) . '/database/migrations/*.sql') ?: [];

sort($migrations);

foreach ($migrations as $file) {
    $name = basename($file);

    $check = $pdo->prepare(
        'SELECT 1 FROM migrations WHERE migration = ?'
    );

    $check->execute([$name]);

    if ($check->fetchColumn()) {
        echo "Skipped {$name}\n";
        continue;
    }

    echo "Applying {$name}...\n";

    try {
        // Start transaction (if supported)
        if (!$pdo->inTransaction()) {
            $pdo->beginTransaction();
        }

        $sql = file_get_contents($file);

        if ($sql === false) {
            throw new RuntimeException("Unable to read migration file: {$name}");
        }

        $pdo->exec($sql);

        $pdo->prepare(
            'INSERT INTO migrations (migration) VALUES (?)'
        )->execute([$name]);

        // MySQL automatically commits on many DDL statements
        // (CREATE TABLE, ALTER TABLE, etc.), so only commit if
        // a transaction is still active.
        if ($pdo->inTransaction()) {
            $pdo->commit();
        }

        echo "✓ Applied {$name}\n";

    } catch (Throwable $e) {

        if ($pdo->inTransaction()) {
            $pdo->rollBack();
        }

        fwrite(STDERR, PHP_EOL);
        fwrite(STDERR, "Migration failed: {$name}" . PHP_EOL);
        fwrite(STDERR, "Exception : " . get_class($e) . PHP_EOL);
        fwrite(STDERR, "Message   : " . $e->getMessage() . PHP_EOL);

        exit(1);
    }
}

echo PHP_EOL . "All migrations completed successfully." . PHP_EOL;
