if($argc!==3){fwrite(STDERR,"Usage: bin/create-admin email password\n");exit(1);} $service=(new App\Infrastructure\Container)->get(App\Services\AuthService::class);if(!$service->bootstrap($argv[1],$argv[2])){fwrite(STDERR,"An admin already exists.\n");exit(1);} echo "Admin created.\n";
